// 校园小吃点评 - 数据库模型定义
// 使用 SQLite 作为初期数据库

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========== 用户 ==========
model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  nickname      String
  avatar        String   @default("")
  passwordHash  String
  school        String   @default("")
  email         String   @default("")
  level         Int      @default(1)
  role          String   @default("user")  // user | admin
  authStatus    String   @default("none") // none | email | verified
  preferences   String   @default("[]")   // JSON 数组
  reviewCount   Int      @default(0)
  likeReceived  Int      @default(0)
  violationCount Int     @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews       Review[]
  replies       Reply[]
  likes         Like[]
  favorites     Favorite[]
  reports       Report[]

  @@index([phone])
  @@index([school])
  @@index([role])
}

// ========== 商户 ==========
model Merchant {
  id          String   @id @default(cuid())
  name        String
  category    String   // 食堂 | 小吃街 | 周边餐馆 | 外卖 | 饮品甜品 | 夜市
  subCategory String   @default("")
  address     String
  avgPrice    Float    @default(0)
  rating      Float    @default(0)
  // 五维度评分
  ratingTaste    Float @default(0)
  ratingHygiene  Float @default(0)
  ratingService  Float @default(0)
  ratingValue    Float @default(0)
  ratingPortion  Float @default(0)
  reviewCount Int      @default(0)
  images      String   @default("[]")   // JSON 数组
  openHours   String   @default("")
  tags        String   @default("[]")   // JSON 数组
  popularDishes String  @default("[]")  // JSON 数组
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]
  favorites   Favorite[]

  @@index([category])
  @@index([rating])
  @@index([name])
}

// ========== 评价 ==========
model Review {
  id            String   @id @default(cuid())
  userId        String
  merchantId    String
  // 五维度评分
  ratingTaste   Float
  ratingHygiene Float
  ratingService Float
  ratingValue   Float
  ratingPortion Float
  overallRating Float
  content       String
  images        String   @default("[]")   // JSON 数组
  videoUrl      String   @default("")
  likes         Int      @default(0)
  richness      Float    @default(1.0)    // 内容丰富度系数
  status        String   @default("pending") // pending | approved | rejected | hidden
  isFeatured    Boolean  @default(false)
  // 风控字段
  riskScore     Int      @default(0)      // 0-100 风险分
  riskLevel     String   @default("low")  // low | medium | high | critical
  riskFlags     String   @default("[]")   // JSON 数组，风险标记
  deviceHash    String   @default("")     // 设备指纹
  moderatedAt   DateTime?                 // 审核时间
  moderatedBy   String   @default("")     // 审核人
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  replies       Reply[]
  reviewLikes   Like[]

  @@index([userId])
  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
  @@index([overallRating])
  @@index([merchantId, status])
  @@index([riskLevel])
}

// ========== 回复 ==========
model Reply {
  id         String   @id @default(cuid())
  userId     String
  reviewId   String
  content    String
  isMerchant Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

// ========== 点赞 ==========
model Like {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId])
}

// ========== 收藏 ==========
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  merchantId String
  groupName  String   @default("默认")
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantId])
  @@index([userId])
}

// ========== 举报 ==========
model Report {
  id          String   @id @default(cuid())
  userId      String
  reviewId    String   @default("")
  reason      String   // 虚假评价 | 广告内容 | 恶意差评 | 抄袭 | 其他
  description String   @default("")
  status      String   @default("pending") // pending | approved | rejected
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reviewId])
}
